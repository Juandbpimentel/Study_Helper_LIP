# ========================================
# .dockerignore - Study Helper Backend
# Ignorar arquivos desnecessários no build Docker
# ========================================

# Git
.git
.gitignore
.gitattributes
.gitguardian.yml

# Environment files (NUNCA incluir credenciais reais!)
.env
.env.*
!.env.example

# Build artifacts e cache
build/
.gradle/
bin/
out/
target/

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# Documentation (não necessário em runtime)
README.md
GITHUB-SECRETS.md
*.md
!README-PROPERTIES.md

# Docker files (não precisam estar dentro da imagem)
docker-compose.yml
Dockerfile*
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Test results e reports
**/test-results/
**/reports/
coverage/
*.exec

# Temporary files
tmp/
temp/
*.tmp